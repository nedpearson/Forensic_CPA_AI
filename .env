# Forensic CPA AI - Environment Variables Template

# 1. Core Application
FLASK_ENV=development
# Cryptographic secret for browser sessions (generate a secure random string for production)
SESSION_SECRET=secure-random-session-secret-12345
# Set to 'true' in production to enforce HTTPS-only cookies
COOKIE_SECURE=false

# 2. Database Connection
# DB_DIALECT options: 'sqlite' or 'postgres'
DB_DIALECT=sqlite
DATABASE_URL=postgresql://postgres.your-tenant-id:1236ece2b817b9c8241d204edc004911b29405978a42b7cff4e956b26a919b14@209.38.153.191:6543/postgres

# 3. Super Admin Bootstrap
# The application will deterministically seed this user as a super admin on startup if SUPER_ADMIN_BOOTSTRAP is true
SUPER_ADMIN_BOOTSTRAP=true
SUPER_ADMIN_EMAIL=nedpearson@gmail.com
SUPER_ADMIN_PASSWORD=your_secure_password_here

# 4. LLM / AI Configuration (Required for Auto-Categorization & Analytics)
OPENAI_API_KEY=your-openai-api-key-here

# 5. Document Extraction (Optional: For PDF bank statement processing)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-api-key-here

# 6. Headless Uploads (Optional: For automated API-driven ingestions)
UPLOAD_AUTH_TOKEN=your-upload-bearer-token-here

# 7. Demo Mode (Optional)
# Set to 'true' to enable the "Log in as Demo" endpoint and provision mock data
DEMO_SEED_ENABLED=true
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_CLIENT_SECRET=your_plaid_client_secret
QUICKBOOKS_CLIENT_ID=your_qb_id
QUICKBOOKS_CLIENT_SECRET=your_qb_secret

# 8. Integrations Framework
ENABLE_INTEGRATIONS=true
ENABLE_GOOGLE=true
ENABLE_QB=true
OAUTH_ENCRYPTION_KEY=z-KYzLKAPqvnZKQ3sshOmFi-OYUfb8WT3qrgQogNyiU=
